<-- Layout.astro -->
---
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style>
      :root {
        --deep-void: hsl(230, 40%, 5%);
        --electric-cyan: hsl(180, 100%, 50%);
        --amethyst-glow: hsl(270, 80%, 60%);
        --frosted-slate: hsla(230, 30%, 15%, 0.6);
        --pure-alabaster: hsl(0, 0%, 98%);
        --muted-alabaster: hsl(230, 20%, 70%);
      }

      body {
        background-color: var(--deep-void);
        color: var(--pure-alabaster);
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
        overflow-x: hidden;
      }

      .glass-panel {
        background: var(--frosted-slate);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
      }

      .glow-border {
        position: relative;
      }
      .glow-border::after {
        content: '';
        position: absolute;
        inset: -1px;
        background: linear-gradient(45deg, var(--electric-cyan), var(--amethyst-glow));
        z-index: -1;
        border-radius: inherit;
        opacity: 0;
        transition: opacity 0.3s ease;
      }
      .glow-border:hover::after {
        opacity: 1;
      }

      /* Kinetic Typography Base */
      .split-text {
        display: inline-block;
        overflow: hidden;
        vertical-align: bottom;
      }
      .split-text span {
        display: inline-block;
        transform: translateY(100%);
        transition: transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
      }
      .split-text.animated span {
        transform: translateY(0%);
      }
    </style>
  </head>
  <body>
    <slot />
    <script src="https://unpkg.com/@studio-freight/lenis@1.0.33/dist/lenis.min.js"></script>
    <script>
      const lenis = new Lenis();
      function raf(time) {
        lenis.raf(time);
        requestAnimationFrame(raf);
      }
      requestAnimationFrame(raf);
    </script>
  </body>
</html>