<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;800&display=swap" rel="stylesheet">
    <style is:global>
        :root {
            --color-deep-space: hsl(222, 47%, 4%);
            --color-electric-violet: hsl(263, 97%, 60%);
            --color-cyan-neon: hsl(180, 100%, 50%);
            --color-glass: hsl(210, 20%, 12% / 0.6);
            --color-frost: hsl(210, 20%, 98%);
        }

        body {
            background-color: var(--color-deep-space);
            color: var(--color-frost);
            font-family: 'Plus Jakarta Sans', sans-serif;
            margin: 0;
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
        }

        .glass-card {
            backdrop-filter: blur(16px) saturate(180%);
            background: var(--color-glass);
            border: 1px solid rgba(255, 255, 255, 0.1);
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
            border-radius: 24px;
            transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        .glass-card:hover {
            transform: translateY(-5px) scale(1.01);
            border-color: var(--color-electric-violet);
        }

        .glow-orb {
            position: absolute;
            width: 40vw;
            height: 40vw;
            border-radius: 50%;
            filter: blur(100px);
            z-index: -1;
            opacity: 0.15;
            pointer-events: none;
        }

        .kinetic-text {
            transition: font-weight 0.5s ease, letter-spacing 0.5s ease;
        }
    </style>
</head>
<body>
    <div class="glow-orb" style="background: var(--color-electric-violet); top: -10%; left: -10%;"></div>
    <div class="glow-orb" style="background: var(--color-cyan-neon); bottom: -10%; right: -10%;"></div>
    <slot />
</body>
</html>