---
import Layout from '../layouts/Layout.astro';
---
<Layout>
    <main class="max-w-7xl mx-auto px-6 py-20">
        <!-- Hero Section -->
        <section class="text-center mb-32 relative">
            <div class="inline-block px-4 py-1.5 mb-6 text-sm font-medium tracking-wider uppercase rounded-full border border-white/10 bg-white/5 backdrop-blur-md text-cyan-400 animate-pulse">
                v7.0 Engine Now Live
            </div>
            <h1 class="text-6xl md:text-8xl font-extrabold tracking-tight mb-8 leading-tight">
                Optimize Your <br />
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-violet-400 to-cyan-400">
                    Digital Velocity
                </span>
            </h1>
            <p class="text-lg md:text-xl text-gray-400 max-w-2xl mx-auto mb-12 leading-relaxed">
                Transition from a standard website to a high-performance revenue engine. 
                Glassmorphic precision, AI-driven speed, and conversion-first architecture.
            </p>
            <div class="flex flex-col sm:flex-row justify-center gap-6">
                <a href="#analyze" class="px-8 py-4 bg-violet-600 hover:bg-violet-500 text-white font-bold rounded-2xl transition-all transform hover:scale-105 shadow-[0_0_20px_rgba(139,92,246,0.4)]">
                    Start Free Analysis
                </a>
                <a href="#book" class="px-8 py-4 glass-card text-white font-bold rounded-2xl transition-all hover:bg-white/10">
                    Book Strategy Call
                </a>
            </div>
        </section>

        <!-- Bento Grid Section -->
        <section class="grid grid-cols-1 md:grid-cols-12 gap-6 mb-32">
            <!-- Large Feature: Before/After -->
            <div class="md:col-span-7 glass-card p-8 flex flex-col justify-between min-h-[400px] group">
                <div>
                    <h3 class="text-3xl font-bold mb-4">Visual Performance Shift</h3>
                    <p class="text-gray-400 mb-8">Experience the immediate impact of our Core Web Vitals overhaul.</p>
                </div>
                <div class="relative h-48 bg-black/40 rounded-xl border border-white/5 overflow-hidden">
                    <div class="absolute inset-0 flex items-center justify-center text-xs text-gray-600 uppercase tracking-widest">
                        [ Interactive Before/After Slider Component ]
                    </div>
                    <div class="absolute top-0 left-0 w-1/2 h-full bg-violet-500/10 border-r border-violet-500/50 backdrop-blur-sm flex items-center justify-center">
                        <span class="text-[10px] font-bold text-violet-400">BEFORE</span>
                    </div>
                </div>
            </div>

            <!-- Medium Feature: API Ticker -->
            <div class="md:col-span-5 glass-card p-8 flex flex-col justify-between">
                <h3 class="text-2xl font-bold mb-4">Real-time Optimization</h3>
                <div class="space-y-4">
                    <div class="flex justify-between items-center p-3 bg-white/5 rounded-lg border border-white/5">
                        <span class="text-sm text-gray-400">LCP Reduction</span>
                        <span class="text-cyan-400 font-mono font-bold">-1.2s</span>
                    </div>
                    <div class="flex justify-between items-center p-3 bg-white/5 rounded-lg border border-white/5">
                        <span class="text-sm text-gray-400">FID Improvement</span>
                        <span class="text-cyan-400 font-mono font-bold">+42%</span>
                    </div>
                    <div class="flex justify-between items-center p-3 bg-white/5 rounded-lg border border-white/5">
                        <span class="text-sm text-gray-400">SEO Authority</span>
                        <span class="text-cyan-400 font-mono font-bold">+18pts</span>
                    </div>
                </div>
            </div>

            <!-- Small Feature 1 -->
            <div class="md:col-span-4 glass-card p-8 text-center">
                <div class="text-4xl mb-4">⚡️</div>
                <h4 class="text-xl font-bold mb-2">Instant Load</h4>
                <p class="text-sm text-gray-400">Sub-second page loads across all global regions.</p>
            </div>

            <!-- Small Feature 2 -->
            <div class="md:col-span-4 glass-card p-8 text-center">
                <div class="text-4xl mb-4">💎</div>
                <h4 class="text-xl font-bold mb-2">Elite UX</h4>
                <p class="text-sm text-gray-400">Apple-inspired minimalism for higher trust.</p>
            </div>

            <!-- Small Feature 3 -->
            <div class="md:col-span-4 glass-card p-8 text-center">
                <div class="text-4xl mb-4">📈</div>
                <h4 class="text-xl font-bold mb-2">Lead Gen</h4>
                <p class="text-sm text-gray-400">Engineered for conversion and lead capture.</p>
            </div>
        </section>

        <!-- Analysis Hub Teaser -->
        <section id="analyze" class="glass-card p-12 text-center relative overflow-hidden">
            <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-violet-500 to-transparent"></div>
            <h2 class="text-4xl font-bold mb-6">Ready to see your score?</h2>
            <p class="text-gray-400 mb-10 max-w-xl mx-auto">Enter your URL and our AI Swarm will perform a deep-dive audit of your performance, accessibility, and SEO in seconds.</p>
            <div class="flex max-w-md mx-auto gap-3">
                <input type="text" placeholder="https://yourwebsite.com" class="flex-1 px-6 py-4 bg-black/40 border border-white/10 rounded-2xl text-white focus:outline-none focus:border-violet-500 transition-colors" />
                <button class="px-6 py-4 bg-white text-black font-bold rounded-2xl hover:bg-gray-200 transition-colors">
                    Analyze
                </button>
            </div>
        </section>
    </main>

    <script>
        // Simple Intersection Observer for Fade-in effects
        const observerOptions = {
            threshold: 0.1
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.style.opacity = "1";
                    entry.target.style.transform = "translateY(0)";
                }
            });
        }, observerOptions);

        document.querySelectorAll('.glass-card').forEach(card => {
            card.style.opacity = "0";
            card.style.transform = "translateY(20px)";
            card.style.transition = "all 0.6s cubic-bezier(0.22, 1, 0.36, 1)";
            observer.observe(card);
        });
    </script>
</Layout>