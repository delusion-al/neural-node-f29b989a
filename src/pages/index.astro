---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Jiao-Jiao | Aether-Flow Evolution">
  <main class="max-w-7xl mx-auto px-6 py-12">
    
    <!-- HERO BENTO SECTION -->
    <section class="grid grid-cols-1 md:grid-cols-12 gap-6 mb-24 items-stretch">
      <!-- Main Cell: Kinetic Headline -->
      <div class="md:col-span-7 glass-panel rounded-3xl p-12 flex flex-col justify-center relative overflow-hidden group">
        <div class="absolute -top-24 -right-24 w-64 h-64 bg-cyan-500/20 blur-[100px] rounded-full group-hover:bg-violet-500/30 transition-colors duration-700"></div>
        <h1 class="text-6xl md:text-8xl font-extrabold tracking-tighter leading-none mb-6">
          <span class="split-text animated"><span>Aether</span></span>
          <span class="split-text animated text-transparent bg-clip-text bg-gradient-to-r from-[hsl(180,100%,50%)] to-[hsl(270,80%,60%)]"><span>Flow</span></span>
          <br />
          <span class="split-text animated"><span>Evolution</span></span>
        </h1>
        <p class="text-xl text-[hsl(230,20%,70%)] max-w-lg mb-8">
          Architecting high-ticket AI ecosystems that transform raw data into autonomous revenue engines.
        </p>
        <div class="flex gap-4">
          <button class="px-8 py-4 bg-[hsl(180,100%,50%)] text-black font-bold rounded-full hover:scale-105 transition-transform shadow-[0_0_30px_rgba(0,255,255,0.3)]">
            Request Access
          </button>
        </div>
      </div>

      <!-- Sub-Cell A: Live Status -->
      <div class="md:col-span-2 glass-panel rounded-3xl p-8 flex flex-col justify-between">
        <div class="flex items-center gap-2">
          <div class="w-2 h-2 bg-[hsl(180,100%,50%)] rounded-full animate-pulse"></div>
          <span class="text-xs uppercase tracking-widest text-gray-400">Swarm Status</span>
        </div>
        <div class="text-3xl font-mono font-bold text-cyan-400">ACTIVE</div>
        <div class="text-[10px] text-gray-500 font-mono uppercase">v7.3 Stable Core</div>
      </div>

      <!-- Sub-Cell B: Quick Lead Capture -->
      <div class="md:col-span-3 glass-panel rounded-3xl p-8 flex flex-col justify-center">
        <h3 class="text-lg font-bold mb-4">Instant Audit</h3>
        <div class="relative">
          <input type="email" placeholder="email@firm.com" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-cyan-500 transition-colors" />
          <button class="absolute right-2 top-2 px-3 py-1 bg-white/10 hover:bg-white/20 rounded-lg text-xs transition-colors">
            Join
          </button>
        </div>
      </div>
    </section>

    <!-- EXPERTISE GRID -->
    <section class="grid grid-cols-1 md:grid-cols-12 gap-6 mb-24">
      <!-- Cell 1: Featured Case Study (Large) -->
      <div class="md:col-span-6 glass-panel rounded-3xl overflow-hidden group glow-border">
        <div class="h-64 bg-black relative overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-t from-black to-transparent z-10"></div>
          <div class="absolute inset-0 flex items-center justify-center text-gray-700 font-mono text-xs uppercase tracking-widest group-hover:scale-110 transition-transform duration-700">
            [ 4K Cinematic Loop: AI Agent Workflow ]
          </div>
        </div>
        <div class="p-8">
          <h3 class="text-2xl font-bold mb-2">Enterprise Scale-Up</h3>
          <p class="text-[hsl(230,20%,70%)]">Reduced operational overhead by 64% using custom agentic swarms for Fortune 500 logistics.</p>
        </div>
      </div>

      <!-- Cell 2: LLM Fine-Tuning (Medium) -->
      <div class="md:col-span-3 glass-panel rounded-3xl p-8 glow-border">
        <div class="w-12 h-12 bg-cyan-500/20 rounded-xl mb-6 flex items-center justify-center text-cyan-400">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
        </div>
        <h3 class="text-xl font-bold mb-2">LLM Fine-Tuning</h3>
        <p class="text-sm text-gray-400">Domain-specific intelligence tailored to your proprietary datasets.</p>
      </div>

      <!-- Cell 3: Agentic Workflows (Medium) -->
      <div class="md:col-span-3 glass-panel rounded-3xl p-8 glow-border">
        <div class="w-12 h-12 bg-violet-500/20 rounded-xl mb-6 flex items-center justify-center text-violet-400">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
          </svg>
        </div>
        <h3 class="text-xl font-bold mb-2">Agentic Swarms</h3>
        <p class="text-sm text-gray-400">Multi-agent coordination for complex, multi-step business logic.</p>
      </div>

      <!-- Cell 4: Social Proof (Small/Wide) -->
      <div class="md:col-span-12 glass-panel rounded-3xl p-6 flex items-center justify-around opacity-50 grayscale hover:grayscale-0 transition-all duration-500">
        <span class="font-bold text-xl italic tracking-tighter">SAMSUNG</span>
        <span class="font-bold text-xl italic tracking-tighter">NVIDIA</span>
        <span class="font-bold text-xl italic tracking-tighter">OPENAI</span>
        <span class="font-bold text-xl italic tracking-tighter">ANTHROPIC</span>
        <span class="font-bold text-xl italic tracking-tighter">TESLA</span>
      </div>
    </section>

    <!-- INTERACTIVE QUOTE ENGINE -->
    <section class="glass-panel rounded-3xl p-12 mb-24 relative overflow-hidden">
      <div class="absolute top-0 right-0 w-full h-1 bg-gradient-to-r from-cyan-500 to-violet-500"></div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-4xl font-bold mb-6">Project Complexity <span class="text-cyan-400">Estimator</span></h2>
          <p class="text-gray-400 mb-8">Select your required capabilities to see the architectural complexity of your AI swarm.</p>
          <div class="space-y-4">
            {['Custom LLM Fine-tuning', 'Multi-Agent Orchestration', 'Real-time Data Pipeline', 'Enterprise Auth Integration'].map((item) => (
              <label class="flex items-center gap-4 p-4 bg-white/5 border border-white/10 rounded-2xl cursor-pointer hover:bg-white/10 transition-colors">
                <input type="checkbox" class="w-5 h-5 accent-cyan-500" />
                <span class="text-sm">{item}</span>
              </label>
            ))}
          </div>
        </div>
        <div class="text-center p-12 bg-black/40 rounded-3xl border border-white/5">
          <div class="text-sm uppercase tracking-widest text-gray-500 mb-4">Complexity Index</div>
          <div class="text-8xl font-black text-transparent bg-clip-text bg-gradient-to-b from-white to-gray-600 mb-6">
            0.42
          </div>
          <div class="w-full h-2 bg-white/10 rounded-full overflow-hidden">
            <div class="w-1/3 h-full bg-gradient-to-r from-cyan-500 to-violet-500"></div>
          </div>
          <p class="mt-6 text-xs text-gray-500">Complexity increases based on integration depth and data volume.</p>
        </div>
      </div>
    </section>

    <!-- ELITE ACCESS PORTAL -->
    <section class="text-center py-20">
      <div class="glass-panel max-w-3xl mx-auto p-16 rounded-[3rem] glow-border">
        <h2 class="text-5xl font-bold mb-6">The Elite Access Portal</h2>
        <p class="text-gray-400 mb-10">We only partner with firms ready for exponential scaling. Request a secure invitation to our private AI consultancy.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <button class="px-10 py-4 bg-white text-black font-bold rounded-full hover:bg-cyan-400 transition-colors">
            Continue with Google
          </button>
          <button class="px-10 py-4 glass-panel text-white font-bold rounded-full hover:bg-white/10 transition-colors">
            Apply Manually
          </button>
        </div>
      </div>
    </section>

  </main>
</Layout>